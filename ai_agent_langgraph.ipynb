   },
   "outputs": [],
   "source": "# !  = הרץ פקודה בטרמינל (לא Python)\n# pip install = כלי התקנת חבילות Python\n# -q = quiet, הסתר פלט מיותר\n!pip install -q langgraph langchain-google-genai langchain-community tavily-python"
